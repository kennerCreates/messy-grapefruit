{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-solid-ts-tailwind-vite/main/.vscode/schema/tauri.conf.schema.json",
  "productName": "Sprite Tool",
  "version": "0.1.0",
  "identifier": "com.spritetool.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sprite Tool",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
